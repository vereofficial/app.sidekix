{
  "expo": {
    "name": "Sidekix",
    "slug": "sidekix",
    "version": "3.1",
    "orientation": "portrait",
    "icon": "./assets/lightning-logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sidekix",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-bolt-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vereofficial.vere",
      "icon": "./assets/lightning-logo.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/lightning-logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b24544a7-290a-4248-b34e-e50df0e24568"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b24544a7-290a-4248-b34e-e50df0e24568",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    }
  }
}
