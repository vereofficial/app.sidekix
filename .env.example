# Copy to .env for local dev. For TestFlight/App Store, set the same keys in Expo:
# https://expo.dev → Project → Environment variables → Production
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Cloudflare R2 (optional). If DB paths look like r2/userId/file.jpg, uploads use R2 and the app
# MUST have a public GET base or images/videos spin forever (no Supabase signed URL for r2/ paths).
# Use the R2 bucket “public” URL (r2.dev / custom domain), NOT *.cloudflarestorage.com.
# Set the same EXPO_PUBLIC_* values in Expo → Project → Environment variables for EAS builds.
# EXPO_PUBLIC_USE_R2_MEDIA=1
# EXPO_PUBLIC_R2_PUBLIC_MEDIA_URL=https://pub-xxxxx.r2.dev

# Local `eas build` only: skips Apple Developer "capability sync" on your machine (avoids common
# "bundle cannot be deleted" errors). eas.json env is mainly for Expo's cloud worker; the CLI still
# needs this in your shell, or use: npm run eas:build:ios
EXPO_NO_CAPABILITY_SYNC=1

# Broadcast push CLI (`npm run broadcast:push`). Create the same secret in Supabase → Edge Functions → Secrets.
BROADCAST_PUSH_SECRET=
# Optional overrides (avoids long PowerShell --body lines)
# BROADCAST_TITLE=Sidekix
# BROADCAST_BODY=your message here
